  <div class="releases-container">
    <h1>Microsoft Office 365 Packages</h1>
    <p class="releases-intro">
      We offer a range of Microsoft Office 365 Packages to suit your business needs. From Startup To Corporate
    </p>

    <section class="service-section">
      <h2>Microsoft Office 365 Packages</h2>
      <div class="service-grid">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-mobile-alt"></i></div>
          <h3>Microsoft Office 365 Basic</h3>
          <p class="price">R350 pm</p>
          <ul class="features">
            <li>Mobile & Web Versions</li>
            <li>Excel, Word, PowerPoint, Outlook & OneNote</li>
            <li>Exchange, OneDrive, SharePoint, Teams</li>
            <li>Identity & Access Management</li>
          </ul>
          <a href="https://paystack.shop/pay/365-basic" class="buy-btn">Get MS 365 Basic</a>
        </div>

        <div class="service-card">
          <div class="service-icon"><i class="fas fa-battery-full"></i></div>
          <h3>Microsoft Office 365 Business</h3>
          <p class="price">R650 pm</p>
          <ul class="features">
            <li>Desktop, Web & Mobile Versions</li>
            <li>Excel, Word, PowerPoint, Outlook, OneNote</li>
            <li>Publisher (PC ONly), Access (PC Only)</li>
            <li>Exchange, OneDrive, SharePoint, Teams</li>
          </ul>
          <a href="https://paystack.shop/pay/365-business" class="buy-btn">Get MS 365 Business</a>
        </div>

        <div class="service-card">
          <div class="service-icon"><i class="fas fa-bolt"></i></div>
          <h3>Microsoft Office 365 Business Premium</h3>
          <p class="price">R850 pm</p>
          <ul class="features">
            <li>Desktop, Web & Mobile Versions</li>
            <li>Excel, Word, PowerPoint, Outlook, OneNote</li>
            <li>Publisher (PC ONly), Access (PC Only)</li>
            <li>Exchange, OneDrive, SharePoint, Teams</li>
          </ul>
          <a href="https://paystack.shop/pay/365-premium" class="buy-btn">Get MS 365 Premium</a>
        </div>
      </div>
    </section>
